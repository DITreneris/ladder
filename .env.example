# =============================================================================
# Corporate Ladder — Environment Variables
# Copy to repo root .env and fill in values. Never commit .env to git.
#
# All services read this single root file:
#   - packages/api  (Pydantic settings)
#   - apps/bot      (python-dotenv)
#   - apps/mini-app (Vite envDir → repo root)
#
# Optional: run scripts/setup-env.ps1 or scripts/setup-env.sh to sync copies
# into each service directory.
# =============================================================================
# --- Railway (API + Bot) ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBAPP_SECRET=your_bot_token_from_botfather
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Railway Bot ---
MINI_APP_URL=https://your-mini-app.vercel.app

# --- Vercel (Mini App) ---
VITE_API_URL=https://your-api.railway.app
VITE_BOT_USERNAME=CorporateLadderBot
VITE_PROMPT_ANATOMY_URL=https://www.promptanatomy.app

# --- Local development overrides ---
# VITE_API_URL=http://localhost:8000
# MINI_APP_URL=http://localhost:5173
